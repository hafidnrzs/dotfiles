# Machine-specific git config. Copy this to ~/.gitconfig.local and customize.
# This file is NOT tracked by git.

[user]
    name = Your Name
    email = your@email.com

[credential]
    # In-memory cache for 1 hour (no plaintext on disk).
    helper = cache --timeout=3600

    # Alternatives:
    # Desktop with a secret service (GNOME Keyring, KWallet, etc.). More persistent, still encrypted:
    # helper = /usr/lib/git-core/git-credential-libsecret
    #
    # WSL: use Git Credential Manager from Git for Windows
    # helper = /mnt/c/Program\\ Files/Git/mingw64/bin/git-credential-manager.exe
    #
    # Plaintext store (NOT recommended. Writes tokens to ~/.git-credentials unencrypted):
    # helper = store
